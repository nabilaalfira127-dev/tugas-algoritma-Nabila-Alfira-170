// OUTPUT
void tampilProduk() {
    int pilihan;
    cout << "1. Urut Nama" << endl;
    cout << "2. Urut Rating" << endl;
    cout << "Pilih: ";
    cin >> pilihan;

    if (pilihan == 1) bubbleSort();
    else if (pilihan == 2) quickSort(0, n - 1);

    cout << "=== DAFTAR PRODUK ===" << endl;
    for (int i = 0; i < n; i++) {
        cout << data[i].name << " | ";
        cout << data[i].category << " | ";
        cout << data[i].price << " | ";
        cout << data[i].stock << " | ";
        cout << data[i].rating << endl;
    }
}

// SEARCH (SEQUENTIAL)
void cariProduk() {
    char cari[60];

    cout << "Masukkan nama produk: ";
    cin >> cari;

    bool found = false;

    for (int i = 0; i < n; i++) {
        if (strcmp(data[i].name, cari) == 0) {
            cout << "Produk ditemukan!";
            cout << data[i].name << " | ";
            cout << data[i].category << " | ";
            cout << data[i].price << " | ";
            cout << data[i].stock << " | ";
            cout << data[i].rating << endl;

            found = true;
            break;
        }
    }

    if (!found) {
        cout << "Produk tidak ditemukan!";
    }
}

// MAIN
int main() {
    loadFile();

    int menu;
    do {
        cout << "=== SHOP EASE CLI ===" << endl;
        cout << "1. Tambah Produk\n";
        cout << "2. Tampilkan Produk\n";
        cout << "3. Cari Produk\n";
        cout << "4. Keluar\n";
        cout << "Pilih: ";
        cin >> menu;

        switch (menu) {
            case 1: tambahProduk(); 
												break;
            case 2: tampilProduk(); 
            break;
            case 3: cariProduk(); 
            break;
            case 4: saveFile();
                cout << "Terima kasih!" << endl;
                break;
        }

    } while (menu != 4);

    return 0;
}
