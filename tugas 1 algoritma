#include <iostream>
#include <cstring>
using namespace std;

struct Produk {
    char name[60];
    char category[30];
    double price;
    int stock;
    float rating;
};

Produk data[100];
int n = 0;

// FILE 
void loadFile() {
    FILE *pointer = fopen("shopease_db.txt", "r");
    if (pointer == NULL) return;

    while (fscanf(pointer, " %[^|]|%[^|]|%lf|%d|%f\n",
        data[n].name,
        data[n].category,
        &data[n].price,
        &data[n].stock,
        &data[n].rating) != EOF) {
        n++;
    }

    fclose(pointer);
}

void saveFile() {
    FILE *pointer = fopen("shopease_db.txt", "w");

    for (int i = 0; i < n; i++) {
        fprintf(pointer, "%s|%s|%.0lf|%d|%.1f\n",
            data[i].name,
            data[i].category,
            data[i].price,
            data[i].stock,
            data[i].rating);
    }

    fclose(pointer);
}

// TAMBAH 
void tambahProduk() {
    
    cout << "Nama Produk: ";
    cin >> data[n].name;

    cout << "Kategori: ";
    cin >> data[n].category;

    cout << "Harga: ";
    cin >> data[n].price;

    cout << "Stok: ";
    cin >> data[n].stock;

    cout << "Rating (0-5): ";
    cin >> data[n].rating;

    n++;

    saveFile();

    cout << "Produk berhasil ditambahkan!" << endl;
}

// BUBBLE SORT (Nama ASC) 
void bubbleSort() {
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - i - 1; j++) {
            if (strcmp(data[j].name, data[j + 1].name) > 0) {
                Produk temp;
                temp = data[i];
                data[i] = data[j];
                data[j] = temp;
            }
        }
    }
}

